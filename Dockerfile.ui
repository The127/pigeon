# --- Build stage ---
FROM node:22-alpine AS builder

WORKDIR /app

COPY pigeon-ui/package.json pigeon-ui/package-lock.json ./
RUN npm ci

COPY pigeon-ui/ .
RUN npm run build

# --- Runtime stage ---
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY pigeon-ui/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
